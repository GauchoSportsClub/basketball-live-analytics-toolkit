# Required for insight generation
OPENAI_API_KEY=your_openai_api_key_here

# Optional OpenAI overrides
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional API host/port
API_HOST=0.0.0.0
API_PORT=8000

# Optional web override (Vite)
VITE_API_BASE_URL=http://localhost:8000

# Optional Google login for the web app
VITE_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
